# Backend agents are imported by /api/test-invoice.mjs (Vercel Serverless Function),
# so the agents/ tree must be deployed. We only exclude local data/ caches.
agents/**/data/
agents/orchestrator/

# Tooling that doesn't belong in deployment
make-blueprints/
server/
testing/
_patches/
_scripts/

# Old standalone build artifact
arvo-os.html

# Test PDFs are only needed for CI, not for the running app.
test-pdfs/

# Standard
node_modules/
build/
.env*
.git
.github
