{
  "name": "arvo-os",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://arvo-flow.github.io/flow",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@neondatabase/serverless": "^0.10.4",
    "@vercel/kv": "^3.0.0",
    "axios": "^1.14.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "pdfkit": "^0.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.2",
    "react-scripts": "5.0.1",
    "resend": "^6.12.3",
    "styled-components": "^6.3.12"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build -e flow",
    "server": "node server/index.js",
    "seed": "node server/seed.js",
    "test:webhook": "node server/test-webhook.js",
    "test:invoice": "node agents/test-invoice/cli.js",
    "db:migrate": "node --env-file=.env scripts/migrate.mjs",
    "test:algo": "node --test tests/run.mjs",
    "test:prop": "node tests/property.mjs"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "gh-pages": "^6.3.0"
  }
}
