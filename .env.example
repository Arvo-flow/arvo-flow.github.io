# ── Anthropic (LLM) ──────────────────────────────────────────────────
# Hämta din API-nyckel från https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxx

# ── Databas (Neon PostgreSQL) ─────────────────────────────────────────
# Hämta från Neon Dashboard → ditt projekt → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ── E-post (Resend) ───────────────────────────────────────────────────
# Hämta från https://resend.com/api-keys
RESEND_API_KEY=re_xxxx
RESEND_FROM=Arvo Intelligence <analys@arvo-flow.se>
ARVO_INTERNAL_EMAIL=hej@arvo-flow.se

# ── Publik bas-URL ────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://arvoflow.se

# ── Admin ─────────────────────────────────────────────────────────────
# Slumpmässig sträng — används för att autentisera /admin
ADMIN_TOKEN=välj-en-lång-slumpmässig-sträng

# ── Google OAuth (Gmail) ──────────────────────────────────────────────
# 1. Gå till console.cloud.google.com → APIs & Services → Credentials
# 2. Skapa OAuth-klient (Web application)
# 3. Lägg till redirect URI: https://arvoflow.se/api/auth/gmail-callback
# 4. Aktivera Gmail API under "Enabled APIs"
# 5. Scope som krävs: gmail.readonly + userinfo.email
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
GOOGLE_REDIRECT_URI=https://arvoflow.se/api/auth/gmail-callback

# ── Microsoft OAuth (Outlook) ─────────────────────────────────────────
# 1. Gå till portal.azure.com → Azure Active Directory → App registrations
# 2. Ny registrering, Supported account types: "Accounts in any org + personal"
# 3. Redirect URI (Web): https://arvoflow.se/api/auth/outlook-callback
# 4. API permissions → Microsoft Graph → Delegated: Mail.Read, User.Read, offline_access
# 5. Certificates & secrets → New client secret (kopiera direkt — visas bara en gång)
MICROSOFT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_CLIENT_SECRET=xxxx~xxxx
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://arvoflow.se/api/auth/outlook-callback

# ── WhatsApp Cloud API ───────────────────────────────────────────────
# Skapa en Meta-app på https://developers.facebook.com/
WHATSAPP_ACCESS_TOKEN=EAAxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789
WHATSAPP_VERIFY_TOKEN=arvo-webhook-secret-2026

# ── Server ───────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
