# ── Anthropic (LLM) ──────────────────────────────────────────────────
# Hämta din API-nyckel från https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxx

# ── WhatsApp Cloud API ───────────────────────────────────────────────
# Skapa en Meta-app på https://developers.facebook.com/
# Gå till WhatsApp > API Setup för att hitta dessa värden.

# Permanent eller tillfällig access token från Meta Dashboard
WHATSAPP_ACCESS_TOKEN=EAAxxxx

# Phone Number ID (visas under WhatsApp > API Setup)
WHATSAPP_PHONE_NUMBER_ID=123456789

# Valfri verifieringssträng — du väljer den själv och anger samma i Meta Dashboard
WHATSAPP_VERIFY_TOKEN=arvo-webhook-secret-2026

# ── Server ───────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
