{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "PUBLIC_URL=/ DISABLE_ESLINT_PLUGIN=true react-scripts build",
  "outputDirectory": "build",
  "framework": null,
  "crons": [
    { "path": "/api/cron/update-fx-rate",   "schedule": "0 6 * * *"   },
    { "path": "/api/cron/batch-process",    "schedule": "*/2 * * * *" }
  ],
  "functions": {
    "api/test-invoice.mjs": {
      "maxDuration": 60
    },
    "api/founding-member.mjs": {
      "maxDuration": 15
    },
    "api/send-analysis.mjs": {
      "maxDuration": 30
    },
    "api/cron/update-fx-rate.mjs": {
      "maxDuration": 15
    },
    "api/batch-upload.mjs": {
      "maxDuration": 30
    },
    "api/batch-status.mjs": {
      "maxDuration": 15
    },
    "api/cron/batch-process.mjs": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
