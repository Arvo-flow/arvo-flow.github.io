{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "ignoreCommand": "case \"$VERCEL_GIT_COMMIT_REF\" in claude/*|gh-pages) exit 0;; *) exit 1;; esac",
  "buildCommand": "PUBLIC_URL=/ DISABLE_ESLINT_PLUGIN=true react-scripts build",
  "outputDirectory": "build",
  "framework": null,
  "crons": [
    {
      "path": "/api/cron/update-fx-rate",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/send-reminders",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/generate-briefings",
      "schedule": "0 9 1 * *"
    },
    {
      "path": "/api/cron/drain-ingest",
      "schedule": "*/2 * * * *"
    }
  ],
  "functions": {
    "api/test-invoice.mjs": {
      "maxDuration": 60
    },
    "api/founding-member.mjs": {
      "maxDuration": 15
    },
    "api/send-analysis.mjs": {
      "maxDuration": 30
    },
    "api/send-report.mjs": {
      "maxDuration": 30
    },
    "api/briefing.mjs": {
      "maxDuration": 15
    },
    "api/cron/update-fx-rate.mjs": {
      "maxDuration": 15
    },
    "api/cron/send-reminders.mjs": {
      "maxDuration": 30
    },
    "api/cron/generate-briefings.mjs": {
      "maxDuration": 60
    },
    "api/admin/preview-briefing.mjs": {
      "maxDuration": 30
    },
    "api/auth/gmail-callback.mjs": {
      "maxDuration": 30
    },
    "api/auth/outlook-callback.mjs": {
      "maxDuration": 30
    },
    "api/activate-intelligence.mjs": {
      "maxDuration": 30
    },
    "api/cron/run-price-alerts.mjs": {
      "maxDuration": 60
    },
    "api/inbound-email.mjs": {
      "maxDuration": 60
    },
    "api/cron/drain-ingest.mjs": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}